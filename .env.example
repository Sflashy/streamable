# Private registry hostname (no trailing slash, no protocol)
# Example: registry.example.com  or  192.168.1.10:5000
REGISTRY=your.registry.example.com

# Image tag to pull on the server (default: latest)
IMAGE_TAG=latest

# Host port to expose the app on (default: 3000)
PORT=3000

# Password — required to upload, delete, and edit videos
PASSWORD=changeme
